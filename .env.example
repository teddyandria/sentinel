# --- Serveur HTTP ---
HTTP_ADDR=:8080
LOG_LEVEL=info
# Dossier du frontend BUILDÉ servi par l'API (Vite -> dist/). En dev, on utilise
# plutôt le serveur Vite (make front) qui proxy /api vers le backend.
WEB_DIR=../frontend/dist

# --- Base de données Postgres ---
# DSN utilisé par l'application.
DATABASE_URL=postgres://POSTGRES_USER:POSTGRES_PASSWORD@localhost:5432/POSTGRES_DB?sslmode=disable
# Variables utilisées par docker-compose pour provisionner Postgres.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- NewsAPI (https://newsapi.org) : source des articles ---
NEWS_API_KEY=remplace_par_ta_cle

# --- Mapbox (https://account.mapbox.com) : token PUBLIC (pk.*) de la carte ---
MAPBOX_TOKEN=pk.
# --- Scheduler : période entre deux récupérations (format Go : 30m, 1h, 15m...) ---
FETCH_INTERVAL=30m

# --- Ollama (LLM local, extraction de lieu). Petit modèle = peu de ressources.
# En local : http://localhost:11434. Depuis un conteneur Docker : http://host.docker.internal:11434
OLLAMA_URL=http://localhost:11434
# Modèle de géocodage (petit, sollicité à chaque nouvel article).
OLLAMA_MODEL=llama3.2:1b
# Modèle de rédaction des réponses RAG (plus gros, à la demande).
OLLAMA_ANSWER_MODEL=llama3.2:3b
# Modèle d'embeddings (texte -> vecteur) pour la recherche RAG.
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Fournisseur LLM : "ollama" (dev, local) ou "groq" (prod, cloud gratuit) ---
LLM_PROVIDER=ollama
# Requis si LLM_PROVIDER=groq (https://console.groq.com, gratuit, sans CB)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_ANSWER_MODEL=llama-3.3-70b-versatile
# Embeddings en prod : Groq n'a pas d'API d'embeddings, on utilise Voyage AI
# (free tier généreux). Requis si LLM_PROVIDER=groq.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5-lite
